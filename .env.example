# Office Tracker - Environment Variables Configuration

# HTTP Server Configuration
HTTP_PORT=8080

# Database Configuration
DB_PATH=office.db

# Discord Bot (Optional)
# Leave empty to disable Discord integration
DISCORD_TOKEN=

# Discord Guild Configuration
# Guild IDs for command registration and dashboard setup
DISCORD_EXEC_GUILD_ID=
DISCORD_COMMUNITY_GUILD_ID=

# Discord Dashboard Channel Name (Optional)
# The bot will search for this channel in each guild to set up dashboards
# Defaults to "office-tracker" if not specified
DISCORD_DASHBOARD_CHANNEL_NAME=office-tracker

# Discord Reports Configuration (Optional)
# Set the channel ID where weekly reports should be sent
# Reports are sent every Monday at 9 AM local time
# and every first day of the month at 9 AM local time
# Leave empty to disable weekly reports
# They can be toggled on/off with the /api/reports/weekly endpoint or /reports-toggle Discord command
DISCORD_REPORTS_CHANNEL_ID=

# API Key Authentication (Optional)
# Set to enable API key authentication for all endpoints except /health, /, and /ui
# Example: API_KEY=your-secret-api-key-here
API_KEY=

# CORS Configuration (Optional)
# Set to enable Cross-Origin Resource Sharing
# Use "*" to allow all origins (not recommended for production)
# Or specify comma-separated list: http://localhost:3000,https://example.com
CORS_ORIGINS=

# Production Example:
# HTTP_PORT=8080
# DB_PATH=/var/lib/office-tracker/office.db
# DISCORD_TOKEN=your-discord-bot-token
# DISCORD_EXEC_GUILD_ID=123456789
# DISCORD_COMMUNITY_GUILD_ID=987654321
# DISCORD_DASHBOARD_CHANNEL_NAME=office-tracker
# API_KEY=your-strong-random-api-key
# CORS_ORIGINS=https://myapp.example.com
